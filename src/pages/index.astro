---
import '../styles/global.css';
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="CCTV-RD 即時監視錄影" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700&family=Noto+Sans+TC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>CCTV-RD</title>
  </head>
  <body>
    <div class="splash" id="splash">
      <div class="splash-inner">
        <div class="splash-mark"></div>
        <div class="splash-name">CCTV-RD</div>
        <div class="splash-line"><span></span></div>
      </div>
    </div>

    <div class="app">
      <header class="hdr">
        <div class="hdr-left">
          <span class="hdr-mark"></span>
          <div>
            <div class="hdr-title">即時監視</div>
            <div class="hdr-sub" id="dvr-cam-label">載入中</div>
          </div>
        </div>
        <div class="hdr-mid">
          <span class="sig" id="sig-dot"></span>
          <span class="sig-txt" id="sig-txt">連線中</span>
          <span class="rec-tag" id="rec-ind">REC</span>
        </div>
        <div class="hdr-right">
          <span class="hdr-clock" id="clock">00:00:00</span>
        </div>
      </header>

      <div class="cors-warn" id="cors-warn">
        直播來源可能因跨域限制無法載入，請使用 Chrome 或 Edge 並確認網路正常。
      </div>

      <div class="layout">
        <section class="monitor">
          <div class="frame">
            <div class="frame-corner tl"></div>
            <div class="frame-corner tr"></div>
            <div class="frame-corner bl"></div>
            <div class="frame-corner br"></div>
            <video id="live-video" autoplay muted playsinline crossorigin="anonymous"></video>
            <div class="frame-bar">
              <div class="frame-info">
                <span class="frame-cam" id="cam-name">—</span>
                <span class="frame-id" id="cam-id-label">C000024</span>
              </div>
              <span class="frame-ts" id="live-ts">00:00:00</span>
            </div>
            <div class="frame-load" id="player-spin">
              <div class="load-bar"></div>
              <span>訊號接入中</span>
            </div>
          </div>
        </section>

        <aside class="panel">
          <div class="panel-block">
            <div class="panel-row">
              <button class="btn-rec" id="rec-btn">開始錄影</button>
              <span class="rec-time" id="rec-timer"></span>
            </div>
            <div class="rec-hint" id="rec-status">待機</div>
          </div>

          <div class="panel-block stats">
            <div class="stat">
              <span class="stat-n" id="st-total">0</span>
              <span class="stat-l">錄影段數</span>
            </div>
            <div class="stat">
              <span class="stat-n" id="st-today">0</span>
              <span class="stat-l">今日</span>
            </div>
            <div class="stat">
              <span class="stat-n" id="st-ret">10</span>
              <span class="stat-l">保留天</span>
            </div>
          </div>

          <div class="panel-block grow">
            <div class="panel-hd">錄影紀錄</div>
            <div class="date-list" id="date-list">
              <div class="empty">載入中</div>
            </div>
            <div class="file-list" id="dvr-files">
              <div class="empty">選擇日期</div>
            </div>
          </div>

          <div class="panel-block stor">
            <span class="stor-lbl">儲存空間</span>
            <div class="stor-track"><div class="stor-fill" id="stor-fill"></div></div>
            <span class="stor-val" id="stor-val">—</span>
          </div>
        </aside>
      </div>
    </div>

    <div class="modal" id="modal">
      <div class="modal-inner">
        <div class="modal-top">
          <span id="modal-ttl">播放</span>
          <button class="modal-x" id="modal-close">關閉</button>
        </div>
        <video id="pb" controls></video>
      </div>
    </div>

    <script>
      import '../scripts/app.ts';
    </script>
  </body>
</html>
